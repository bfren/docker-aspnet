        "10-arm-aspnet" => "15d4fdfe1d733346eef63b650d17e5a06dada860dfa497f04d8c646bdf7e2fe9d3d53e700266745ffebcb0f037c824c8bb42d9a9fb7d7fed153e0a769715700a"
        "10-arm64-aspnet" => "8eff014c4f00171dc85f61056831342b1578d88a52fac05770fc855e112051de71f3d4d89f5fd601bc1b9584c1dd83c38a87d6c770f77b9718bb2bc258213921"
        "10-x64-aspnet" => "265df01c5764f0e9da2dec8d55b9814bb230ce1b404016aa0dc56cdb156d5999fc4f67b8b2b439b0144cbbd28ff3eb9b12a3c42fa8a6a0321320ae7d3559e67f"
        "11-arm-aspnet" => "4ad7a3c0ba8a9ca3c4cd47f0ca5ba27cd4994f131419187174be4e36085b14464422175e81611813ea18905eba3985411ecebee69202a573a9bd9e5662ce4609"
        "11-arm64-aspnet" => "637a2638ceb0b12e62a0e39c75e40af372d21d149a0b527588c99f94c7ac4af8662f38ef6fdbc2dcbec920b9c5ea8881a00521e8043199dcaa28ff8b141067f0"
        "11-x64-aspnet" => "2578da41a66e0f0884c075139780a03dc696738c95353eecbaaf9bc7dfe4b8ab75898ac0afefb75e03ca92d24bf1a2ecabe89eff85161c89bdf38a8151dde256"
        _ => { bf write error $"Unsupported .NET download: ($filename)." }
    }

    # verify downloaded file
    bf write $" .. verifying ($filename) download." install/download
    { $"($hash)  ($filename_with_ext)" | ^sha512sum -c - } | bf handle -f {|code, err|
        bf write error $" .. checksum did not match for ($filename)." install/download
    } install/download

    # return filename with extension
    $filename_with_ext
}
