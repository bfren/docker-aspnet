        "10-x64-dotnet" => "039e0032d2508fae91f082df7b4e8921127e23bd01c0fd4d541bca3d612ec752e47b15dbc2f3a2300a21c12e2c755cf5c4b134517f76b4c24d7b56aad94f2edf"
        "11-arm-dotnet" => "2e033d0394dbb46e4097d4605a45a8169adb2403a9a0bfb573a6f692e965adeefe38eb344280d88ab9c7841b63164102495a0840adcabda97cef22117b8e3b99"
        "11-arm64-dotnet" => "8e96aa7d743076497e7498ead68fa8799e35f79f3b8b44b8032f02f39f5c1134f16459026b888bc899ac9dbf6c489133abd025ad1866c84f6ec3a2d45b87f908"
        "11-x64-dotnet" => "444fa50f48b7c38bbd658924575ef140c1f4c610760a4d93477d644d54805439536e3c3171002e152c33341e81085cfb9cc4332bf44534f90335bf03f4d1cd5c"
        "8-arm-aspnet" => "bd1802990f94b62bc1a994ee963236a6abff782938d3fcaa27e9cabe4d2dab285ccaac0a14905a3daf9d0fe1ac12737903a9ffbb8f6d10945ebbc4e02514c92c"
