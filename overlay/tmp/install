        "8-x64-aspnet" => "33085216a4abc1f770e5488d206c087696c9d405333f665c2dc87986fdfbf9d549b10d67eda88eb01e627c54a4fd05756761e35f42bf576ae26b72029f1d7363"
        "9-arm-aspnet" => "2a84974701f15899d1620c259f4cb89edfcccd297fd53ec33267608eebee3fa9caa1f14260b598bf3e0577eea0c6d327a370a162db2419659ce29e28954c44e2"
        "9-arm64-aspnet" => "57b4c70f8f39a400088d9b66b85abf6712ca0bd1122d556bc2614b5199baa7923412517f3e7d36b2dfc78c06aab5904ddae7d244f4d93c01ed1286ca121b6c2b"
